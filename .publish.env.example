# VoidDrift — itch.io publish configuration
#
# Copy this file to .publish.env and fill in your values.
# .publish.env is gitignored and must never be committed.
#
# Butler auth is handled separately via `butler login` — no token needed here.
#
# Format: username/game-slug:channel
# Channel is typically html5 for WASM builds.

ITCHIO_TARGET=your-username/your-game:html5
